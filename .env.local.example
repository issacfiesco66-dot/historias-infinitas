# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Replicate (IA - Stable Diffusion XL)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (pagos)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (correos transaccionales)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Historias Infinitas <hola@historias-infinitas.com>"
EMAIL_REPLY_TO=hola@historias-infinitas.com

# Secreto compartido para los Database Webhooks de Supabase
NOTIFY_WEBHOOK_SECRET=cambia-esto-por-un-string-largo-aleatorio

# Indexa (scraper externo) → HI: autentica POST /api/leads/funeraria y endpoints relacionados.
# Genera uno con: openssl rand -hex 32   (mínimo 16 caracteres)
INDEXA_API_KEY=cambia-esto-por-un-string-largo-aleatorio

# Correo(s) de administrador — separados por coma si son varios.
# Tienen acceso a /dashboard/admin
ADMIN_EMAILS=hola@historias-infinitas.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL del nicho virtual que se usa como DEMO en /partners y en el mensaje de WhatsApp
# de funerarias. Crea el memorial en /dashboard/new, publícalo gratis desde el admin,
# y copia aquí su URL (https://historias-infinitas.com/m/<slug>).
NEXT_PUBLIC_HI_DEMO_MEMORIAL_URL=https://historias-infinitas.com/m/ejemplo
